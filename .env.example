# ── Database ───────────────────────────────────────────────
# Postgres connection string. pg_trgm extension is enabled by the first migration.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/smartcrm

# ── API ────────────────────────────────────────────────────
API_PORT=4000
# Comma-separated allowed origins for the web app (CORS + cookie)
WEB_ORIGIN=http://localhost:5173
# Secret used to sign the session JWT and signed storage URLs. CHANGE IN PROD.
AUTH_SECRET=dev-only-change-me-to-a-long-random-string
# Session lifetime
SESSION_TTL_HOURS=168
# Set true behind HTTPS in production (secure cookie flag)
COOKIE_SECURE=false

# ── First Super Admin seed (§3.1) ──────────────────────────
# Tom's login email. ⚠ CONFIRM BEFORE DEPLOY (on record: tomw@smarthvac.solutions)
SEED_SUPERADMIN_EMAIL=tomw@smarthvac.solutions
SEED_SUPERADMIN_NAME=Tom Walton

# ── Email (invites / password reset) ───────────────────────
# Resend is PRIMARY as soon as RESEND_API_KEY is set (no MAILER_DRIVER edit
# needed). Leave the key blank for dev mode: links are logged to the console +
# storage-dev/outbox.log instead of sent.
# RESEND_FROM_EMAIL must be an address on your Resend-verified domain.
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@smartplan.software
# Optional display-name form; wins over RESEND_FROM_EMAIL when set:
# MAIL_FROM="SmartPlan CRM <no-reply@smartplan.software>"

# ── File storage (collateral) ──────────────────────────────
# dev = local disk under storage-dev/ with HMAC-signed URLs; s3 = S3-compatible (prod)
STORAGE_DRIVER=dev
STORAGE_LOCAL_DIR=storage-dev
# S3 (when STORAGE_DRIVER=s3)
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=smartcrm-collateral
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ── Voice capture AI (ChatGPT / OpenAI) ────────────────────
# Used by POST /api/opportunities/transcribe: Whisper transcribes the voice note,
# then a GPT model extracts structured opportunity fields. Leave blank to disable
# voice capture (the typed form always works).
OPENAI_API_KEY=
OPENAI_TRANSCRIBE_MODEL=whisper-1
OPENAI_EXTRACT_MODEL=gpt-4o-mini

# ── Apollo.io (v1.1 — reserved, unused in v1) ──────────────
APOLLO_API_KEY=
APOLLO_WATERFALL_ENABLED=false

# ── SmartPlan → Advise ingest (referral commissions) ───────
# Shared secret for the server-to-server endpoints POST
# /api/smartplan-transactions/ingest and /activation. MUST equal
# ADVISE_INGEST_SECRET in the SmartPlan app's .env. Blank = ingest disabled
# (every push from SmartPlan is rejected with 400).
SMARTPLAN_INGEST_SECRET=
