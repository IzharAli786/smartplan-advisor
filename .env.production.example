# ─────────────────────────────────────────────────────────────────────────────
# Production environment for advise.smartplan.software
#
# Copy this to  C:\smartplan-advisor\.env  ON THE SERVER and fill the blanks.
# This template is safe to commit (no secrets). The real .env is git-ignored and
# never leaves the box (the deploy tarball excludes it).
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=production

# ── Database ───────────────────────────────────────────────
# FILL THIS IN with your separate DB server / credentials. The first migration
# runs CREATE EXTENSION for BOTH pg_trgm AND pgcrypto (gen_random_uuid()), so the
# DB user must be able to create extensions — either a DB owner/superuser, or have
# an admin pre-create both once:
#   CREATE EXTENSION IF NOT EXISTS pg_trgm;
#   CREATE EXTENSION IF NOT EXISTS pgcrypto;
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME

# ── API ────────────────────────────────────────────────────
# MUST match the reverse-proxy target (localhost:5052) in apps/web/public/web.config.
API_PORT=5052

# Public base URL of the app. This is used for BOTH the CORS origin AND to build
# invite / password-reset / public-quote links that get emailed, so it MUST be the
# real HTTPS origin. (Only the first comma-separated entry is used for links.)
WEB_ORIGIN=https://advise.smartplan.software

# Signs the session JWT and the signed storage URLs. Generate a long random value.
# PowerShell:  [Convert]::ToBase64String((1..48 | ForEach-Object { Get-Random -Maximum 256 }))
AUTH_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING

SESSION_TTL_HOURS=168

# HTTPS in prod → the session cookie must be Secure.
COOKIE_SECURE=true

# ── First Super Admin seed (created by `pnpm db:seed`) ──────
# ⚠ Confirm Tom's real login email before seeding.
SEED_SUPERADMIN_EMAIL=tomw@smarthvac.solutions
SEED_SUPERADMIN_NAME=Tom Walton

# ── Email (invites / password reset) ───────────────────────
# 'dev' just logs the link to the pm2 logs + apps/api/storage-dev/outbox.log — OK
# to bootstrap, but switch to a real provider before onboarding real advisors.
MAILER_DRIVER=dev
MAIL_FROM="SmartPlan CRM <no-reply@smartplan.software>"
# RESEND_API_KEY=

# ── File storage (collateral, logos, avatars) ─────────────
# NOTE: file bytes are stored IN POSTGRES (the file_blobs table), served only via
# short-lived HMAC-signed /files URLs. There is no local-disk or S3 backend in the
# code — STORAGE_DRIVER / STORAGE_LOCAL_DIR / S3_* are NOT consumed, so don't rely
# on them to change where files live.
#   => Back up the DATABASE (not the box disk). Uploaded files survive redeploys
#      because they never touch C:\smartplan-advisor (which is rebuilt each deploy).

# ── Voice capture (optional — leave blank to disable) ──────
OPENAI_API_KEY=
OPENAI_TRANSCRIBE_MODEL=whisper-1
OPENAI_EXTRACT_MODEL=gpt-4o-mini

# ── SmartPlan → Advise ingest (referral commissions) ───────
# Shared secret for POST /api/smartplan-transactions/ingest and /activation —
# SmartPlan pushes referral activations, paid invoices, and payment-failure
# adjustments here. MUST equal ADVISE_INGEST_SECRET in the SmartPlan box's
# .env. Blank = ingest disabled (pushes rejected with 400). Generate like
# AUTH_SECRET and paste the SAME value into both boxes.
SMARTPLAN_INGEST_SECRET=
