<?xml version="1.0" encoding="UTF-8"?>
<!--
  IIS static-host + reverse-proxy config for advisor.smartplan.software.

  This file lives in apps/web/public/, so `vite build` copies it into
  apps/web/dist/ on every build — i.e. it is always present in the folder IIS
  serves (C:\smartplan-advisor\apps\web\dist). IIS refuses to serve web.config to
  clients, so it is not publicly downloadable.

  Topology:
    Browser --HTTPS--> IIS (TLS via win-acme) --> {
        /api/*, /files/*   -> reverse-proxied to the Fastify API (PM2) on localhost:5052
        everything else    -> served as static PWA files from this folder,
                              SPA-fallback to /index.html
    }

  Box requirements (already true for the dev1 site on this server):
    - IIS "URL Rewrite" module
    - "Application Request Routing" (ARR) with server-level "Enable proxy" = ON

  IMPORTANT: the port 5052 below MUST match API_PORT in C:\smartplan-advisor\.env.
-->
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <!-- win-acme / Let's Encrypt HTTP-01 validation must reach the filesystem.
             MUST be first, or the proxy/SPA rules swallow the challenge and cert
             issuance + renewal fail. -->
        <rule name="ACME-Challenge" stopProcessing="true">
          <match url="^\.well-known/acme-challenge/.*" />
          <action type="None" />
        </rule>

        <!-- API + signed file downloads -> the Node process. Query strings are
             forwarded automatically (appendQueryString defaults to true). -->
        <rule name="ReverseProxyToApi" stopProcessing="true">
          <match url="^(api|files)(/.*)?$" />
          <action type="Rewrite" url="http://localhost:5052/{R:0}" />
        </rule>

        <!-- SPA fallback: any path that is not a real file or directory -> index.html
             (React Router then handles /set-password, /q/:token, etc.). -->
        <rule name="SPA-Fallback" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
          </conditions>
          <action type="Rewrite" url="/index.html" />
        </rule>
      </rules>
    </rewrite>

    <!-- Serve index.html for "/" -->
    <defaultDocument>
      <files>
        <clear />
        <add value="index.html" />
      </files>
    </defaultDocument>

    <staticContent>
      <remove fileExtension=".webmanifest" />
      <mimeMap fileExtension=".webmanifest" mimeType="application/manifest+json" />
      <remove fileExtension=".svg" />
      <mimeMap fileExtension=".svg" mimeType="image/svg+xml" />
      <remove fileExtension=".woff2" />
      <mimeMap fileExtension=".woff2" mimeType="font/woff2" />
    </staticContent>

    <httpProtocol>
      <customHeaders>
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-Frame-Options" value="SAMEORIGIN" />
        <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
        <add name="Strict-Transport-Security" value="max-age=31536000; includeSubDomains" />
      </customHeaders>
    </httpProtocol>

    <urlCompression doStaticCompression="true" doDynamicCompression="true" />
  </system.webServer>
</configuration>
